<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundryBooking.Maui.Views.NewsPage"
             BackgroundColor="{AppThemeBinding Light=#F5F0EB, Dark=#1C1C1E}">
    <ContentPage.Content>
        <VerticalStackLayout>
            <Grid>
                <Image
                    Source="laundrypic2.png"
                    Aspect="AspectFill"
                    HeightRequest="350"/>
                <Label
                    Text="TvättBokaren"
                    TextColor="White"
                    FontSize="21"
                    FontFamily="OpenSansSemibold"
                    Padding="16"
                    VerticalOptions="Start"/>
            </Grid>
            <Grid
                RowDefinitions="Auto, Auto"
                Padding="16"
                RowSpacing="12">
                <Label
                    Grid.Row="0"
                    Text="Nyheter"
                    FontSize="24"
                    FontFamily="OpenSansSemibold"
                    TextColor="#3D6B68"/>
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding NewsPosts}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BackgroundColor="{AppThemeBinding Light=#E8E0D5, Dark=#2C2C2C}"
                                StrokeShape="RoundRectangle 12"
                                Padding="16"
                                Margin="0,4">
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding Title}"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="17"
                                            TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}"/>
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding CreatedAt}"
                                            FontSize="13"
                                            TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}"/>
                                    </Grid>
                                    <Label
                                        Text="{Binding Content}"
                                        FontSize="14"
                                        TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>

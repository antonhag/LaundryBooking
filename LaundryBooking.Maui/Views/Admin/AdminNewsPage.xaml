<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundryBooking.Maui.Views.Admin.AdminNewsPage"
             BackgroundColor="{AppThemeBinding Light=#F5F0EB, Dark=#1C1C1E}">
    <ContentPage.Content>
        <Grid 
            RowDefinitions="Auto, Auto, *">
            <Grid 
                Grid.Row="0">
                <Image
                    Source="laundrypic2.png"
                    Aspect="AspectFill"
                    HeightRequest="200">
                </Image>
                <VerticalStackLayout
                    Padding="16"
                    VerticalOptions="Start">
                    <Label
                        Text="TvättBokaren"
                        TextColor="White"
                        FontSize="21"
                        FontFamily="OpenSansSemibold">
                    </Label>
                    <Label
                        Text="Admin"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold">
                    </Label>
                </VerticalStackLayout>
            </Grid>
            
            <!-- Skapa nya nyheter -->
            <VerticalStackLayout 
                Grid.Row="1" 
                Spacing="12" 
                Padding="16,12,16,12">
                <Label
                    Text="Ny nyhet"
                    FontSize="24"
                    FontFamily="OpenSansSemibold"
                    TextColor="#3D6B68">
                </Label>
                <Picker
                    Title="Välj förening"
                    ItemsSource="{Binding Cooperatives}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCooperative}"
                    BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    TitleColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}">
                </Picker>
                <Entry
                    Placeholder="Titel"
                    Text="{Binding NewTitle}"
                    BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    PlaceholderColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}"
                    FontSize="15">
                </Entry>
                <Editor
                    Placeholder="Innehåll"
                    Text="{Binding NewContent}"
                    BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    PlaceholderColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}"
                    HeightRequest="100"
                    FontSize="15">
                </Editor>
                <Button
                    Text="Publicera"
                    Command="{Binding CreatePostCommand}"
                    BackgroundColor="#3D6B68"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="60"
                    FontFamily="OpenSansSemibold">
                </Button>
            </VerticalStackLayout>

            <!-- Lista med nyheter -->
            <CollectionView Grid.Row="2" ItemsSource="{Binding NewsPosts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            BackgroundColor="{AppThemeBinding Light=#E8E0D5, Dark=#2C2C2C}"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            Margin="16,4">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label
                                        Text="{Binding HousingCooperativeName}"
                                        FontSize="13"
                                        FontFamily="OpenSansSemibold"
                                        TextColor="#3D6B68">
                                    </Label>
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="16"
                                        FontFamily="OpenSansSemibold"
                                        TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}">
                                    </Label>
                                    <Label
                                        Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}">
                                    </Label>
                                </VerticalStackLayout>
                                <Button
                                    Grid.Column="1"
                                    Text="Ta bort"
                                    BackgroundColor="#B5673A"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    VerticalOptions="Center"
                                    Clicked="OnDeleteClicked">
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ContentPage.Content>
</ContentPage>

<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundryBooking.Maui.Views.Admin.AdminHousingPage"
             BackgroundColor="{AppThemeBinding Light=#F5F0EB, Dark=#1C1C1E}">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, Auto, *">

            <!-- Bildhuvud -->
            <Grid Grid.Row="0">
                <Image
                    Source="laundrypic2.png"
                    Aspect="AspectFill"
                    HeightRequest="200">
                </Image>
                <VerticalStackLayout
                    Padding="16"
                    VerticalOptions="Start">
                    <Label
                        Text="TvättBokaren"
                        TextColor="White"
                        FontSize="21"
                        FontFamily="OpenSansSemibold">
                    </Label>
                    <Label
                        Text="Admin"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold">
                    </Label>
                </VerticalStackLayout>
            </Grid>

            <!-- Skapar-formulär -->
            <VerticalStackLayout Grid.Row="1" Spacing="12" Padding="16,12,16,12">
                <Label
                    Text="Ny bostadsrättsförening"
                    FontSize="24"
                    FontFamily="OpenSansSemibold"
                    TextColor="#3D6B68">
                </Label>
                <Entry
                    Placeholder="Namn"
                    Text="{Binding NewName}"
                    BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    PlaceholderColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}"
                    FontSize="15">
                </Entry>
                <Entry
                    Placeholder="Lägenheter, t.ex. 1101,1102,1103"
                    Text="{Binding NewApartmentNumbers}"
                    BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    PlaceholderColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}"
                    FontSize="15">
                </Entry>
                <Button
                    Text="Skapa förening"
                    Command="{Binding CreateCommand}"
                    BackgroundColor="#3D6B68"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="60"
                    FontFamily="OpenSansSemibold">
                </Button>
            </VerticalStackLayout>

            <!-- Lista med föreningar -->
            <CollectionView Grid.Row="2" ItemsSource="{Binding Cooperatives}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            BackgroundColor="{AppThemeBinding Light=#E8E0D5, Dark=#2C2C2C}"
                            StrokeShape="RoundRectangle 12"
                            Padding="16"
                            Margin="16,4">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="17"
                                        FontFamily="OpenSansSemibold"
                                        TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}">
                                    </Label>
                                    <Label
                                        Text="{Binding ApartmentNumbers.Count, StringFormat='{0} lägenheter'}"
                                        FontSize="14"
                                        TextColor="{AppThemeBinding Light=Grey, Dark=#8E8E93}">
                                    </Label>
                                </VerticalStackLayout>
                                <Button
                                    Grid.Column="1"
                                    Text="Ta bort"
                                    BackgroundColor="#B5673A"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    VerticalOptions="Center"
                                    Clicked="OnClickedDelete">
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ContentPage.Content>
</ContentPage>

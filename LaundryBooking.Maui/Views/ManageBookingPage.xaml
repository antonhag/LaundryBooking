<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundryBooking.Maui.Views.ManageBookingPage"
             BackgroundColor="{AppThemeBinding Light=#F5F0EB, Dark=#1C1C1E}">
    <ContentPage.Content>
        <VerticalStackLayout>
            <Grid>
                <Image
                    Source="laundrypic2.png"
                    Aspect="AspectFill"
                    HeightRequest="350"/>
                <Label
                    Text="TvättBokaren"
                    TextColor="White"
                    FontSize="21"
                    FontFamily="OpenSansSemibold"
                    Padding="16"
                    VerticalOptions="Start"/>
            </Grid>
            <Label
                Text="Hantera bokningar"
                FontSize="24"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                TextColor="#3D6B68"
                Padding="16,8"/>
            <CollectionView
                ItemsSource="{Binding Bookings}"
                Margin="16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            BackgroundColor="{AppThemeBinding Light=#D4C9BC, Dark=#3A3A3C}"
                            StrokeShape="RoundRectangle 12"
                            Margin="0,4"
                            Padding="16">
                            <Grid
                                RowDefinitions="Auto, Auto">
                                <VerticalStackLayout Grid.Row="0">
                                    <Label
                                        Text="{Binding Date}"
                                        FontFamily="OpenSansSemibold"
                                        TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}"/>
                                    <Label
                                        Text="{Binding TimeSlotDisplayText}"
                                        TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EBEBEB}"/>
                                </VerticalStackLayout>
                                <Button
                                    Grid.Row="0"
                                    Text="Ta bort"
                                    BackgroundColor="#C0392B"
                                    TextColor="White"
                                    CornerRadius="8"
                                    VerticalOptions="Start"
                                    HorizontalOptions="End"
                                    Clicked="OnClickedDeleteBooking"
                                    CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>
